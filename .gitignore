/minimal_transformer_en_zh_5090_outputs_v4/
/stage5*/
/stage5_*/
/stage5_dataset/
/stage5_1_dataset/
/stage5_2_dataset/
/stage5_backup*/
/stage5_1_backup*/

# Local scratch scripts and legacy experiments kept outside the public repo layout
/*.py
/Encoder-Decoder*.py
/Hidden-states-test.py
/Makefile
/images/
/writeup/
/.github/

# Generated documentation assets from local notes
/docs/*.html
/docs/*.css
/docs/header-includes.yaml

# Archives and temporary files
*.tgz
.data

# --- Allow v0_baseline checkpoint, logs, results and trained tokenizer ---
!encoder_decoder/v0_baseline/checkpoints/
!encoder_decoder/v0_baseline/checkpoints/*.pt
!encoder_decoder/v0_baseline/logs/
!encoder_decoder/v0_baseline/logs/**
!encoder_decoder/v0_baseline/results/
!encoder_decoder/v0_baseline/results/**

# v1 curriculum local outputs and non-uploaded evaluation files
/outputs/
/encoder_decoder/v1_curriculum/outputs/
/encoder_decoder/v1_curriculum/checkpoints/
/encoder_decoder/v1_curriculum/logs/
/encoder_decoder/v1_curriculum/results/
